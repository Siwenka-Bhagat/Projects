    {
      "name": "Get Status",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status should be 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "    });\r",
              "const responseBody = pm.response.json();\r",
              "console.log(responseBody);\r",
              "\r",
              "pm.test(\"Status should be OK\", function () {    \r",
              "    pm.expect(responseBody.status).to.eql(\"OK\");\r",
              "    });\r",
              "pm.setNextRequest(\"List of Books\");"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
